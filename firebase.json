{
    "hosting":  {
                    "public":  "build",
                    "ignore":  [
                                   "firebase.json",
                                   "**/.*",
                                   "**/node_modules/**"
                               ],
                    "rewrites":  [
                                     {
                                         "source":  "/api/ai-reply",
                                         "function":  "generateAiReply"
                                     },
                                     {
                                         "source":  "**",
                                         "destination":  "/index.html"
                                     }
                                 ]
                },
    "firestore":  {
                      "rules":  "database.rules.json"
                  },
    "functions":  [
                      {
                          "source":  "functions",
                          "codebase":  "default",
                          "disallowLegacyRuntimeConfig":  true,
                          "ignore":  [
                                         "node_modules",
                                         ".git",
                                         "firebase-debug.log",
                                         "firebase-debug.*.log",
                                         "*.local"
                                     ],
                          "predeploy":  [
                                            "npm --prefix \"$RESOURCE_DIR\" run lint"
                                        ]
                      }
                  ]
}
